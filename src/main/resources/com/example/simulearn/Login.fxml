<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane
    prefHeight="1080.0"
    prefWidth="1920.0"
    stylesheets="@menu.css"
    xmlns="http://javafx.com/javafx/25"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.example.simulearn.LoginController">

    <children>

        <!-- Full page split layout -->
        <HBox spacing="0" prefHeight="1080" prefWidth="1920">

            <!-- ══ LEFT PANEL — Branding ══ -->
            <VBox styleClass="auth-left-panel" alignment="CENTER" spacing="30"
                  prefWidth="860" prefHeight="1080">

                <Label styleClass="auth-brand-icon" text="🌿"/>
                <Label styleClass="auth-brand-name" text="SimuLearn"/>
                <Label styleClass="auth-brand-tagline" maxWidth="500" wrapText="true"
                       text="Your virtual science laboratory. Explore. Simulate. Understand."/>

                <!-- Decorative subject pills -->
                <VBox spacing="14" alignment="CENTER">
                    <HBox spacing="14" alignment="CENTER">
                        <Label styleClass="auth-pill-physics" text="⚡  Physics"/>
                        <Label styleClass="auth-pill-chem"    text="🧪  Chemistry"/>
                    </HBox>
                    <HBox spacing="14" alignment="CENTER">
                        <Label styleClass="auth-pill-math"    text="📐  Mathematics"/>
                        <Label styleClass="auth-pill-bio"     text="🌿  Biology"/>
                    </HBox>
                </VBox>

                <Label styleClass="auth-left-footer" text="Free · Offline · Interactive"/>

            </VBox>

            <!-- ══ RIGHT PANEL — Login Form ══ -->
            <VBox alignment="CENTER" HBox.hgrow="ALWAYS" styleClass="auth-right-panel">

                <VBox styleClass="auth-card" alignment="CENTER" spacing="0">

                    <!-- Header -->
                    <Label styleClass="auth-card-title" text="Welcome back"/>
                    <Label styleClass="auth-card-subtitle" text="Sign in to your SimuLearn account"/>

                    <VBox spacing="20" styleClass="auth-form">

                        <!-- Username / Email -->
                        <VBox spacing="6">
                            <Label styleClass="auth-field-label" text="Username or Email"/>
                            <TextField fx:id="usernameField"
                                       styleClass="auth-input"
                                       promptText="Enter your username or email"/>
                        </VBox>

                        <!-- Password -->
                        <VBox spacing="6">
                            <Label styleClass="auth-field-label" text="Password"/>
                            <PasswordField fx:id="passwordField"
                                           styleClass="auth-input"
                                           promptText="Enter your password"/>
                        </VBox>

                        <!-- Remember Me -->
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <CheckBox fx:id="rememberMe" styleClass="auth-checkbox" text="Remember me"/>
                        </HBox>

                        <!-- Error label -->
                        <Label fx:id="errorLabel" styleClass="auth-error" text="" wrapText="true" maxWidth="360"/>

                        <!-- Login Button -->
                        <Button mnemonicParsing="false" onAction="#handleLogin"
                                styleClass="btn-glow-green auth-submit-btn"
                                text="Sign In →"/>

                        <!-- Divider -->
                        <HBox alignment="CENTER" spacing="12" styleClass="auth-divider-row">
                            <Region HBox.hgrow="ALWAYS" styleClass="auth-divider-line"/>
                            <Label styleClass="auth-divider-text" text="or"/>
                            <Region HBox.hgrow="ALWAYS" styleClass="auth-divider-line"/>
                        </HBox>

                        <!-- Go to Sign Up -->
                        <HBox alignment="CENTER" spacing="6">
                            <Label styleClass="auth-switch-text" text="Don't have an account?"/>
                            <Hyperlink fx:id="goToSignUp" onAction="#openSignUp"
                                       styleClass="auth-link" text="Create one"/>
                        </HBox>

                        <!-- Back to Home -->
                        <HBox alignment="CENTER">
                            <Hyperlink onAction="#goHome" styleClass="auth-link-muted" text="← Back to Home"/>
                        </HBox>

                    </VBox>

                </VBox>

            </VBox>

        </HBox>

    </children>
</StackPane>
