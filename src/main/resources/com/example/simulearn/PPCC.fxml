<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import org.kordamp.ikonli.javafx.*?>

<VBox fx:id="mainContainer" prefHeight="1080.0" prefWidth="1920.0" stylesheets="@menu.css"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.simulearn.SimuLearn.Biology.PPCC.PPCCController">

    <children>

        <!-- NAVBAR -->
        <HBox alignment="CENTER_LEFT" spacing="0" styleClass="navbar">

            <!-- Brand -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <FontIcon iconLiteral="mdi2d-dna" styleClass="brand-icon"/>
                <Label styleClass="brand-name" text="SimuLearn"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Page title -->
            <Label styleClass="sim-page-title" text="Purifying Protein by Column Chromatography">
                <font>
                    <Font name="FontAwesome" size="12.0"/>
                </font>
            </Label>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Back button -->
            <HBox alignment="CENTER" spacing="6">
                <Button mnemonicParsing="false" onAction="#onBackButtonClicked" styleClass="btn-glow-green"
                        text="Back"/>
            </HBox>

            <HBox.margin>
                <Insets right="50.0"/>
            </HBox.margin>
        </HBox>

        <!-- MAIN CONTENT -->
        <ScrollPane fitToWidth="false" prefHeight="1008.0" prefWidth="1920.0" styleClass="main-scroll"
                    VBox.vgrow="ALWAYS">
            <content>
                <HBox prefHeight="1000.0" prefWidth="1916.0" styleClass="sim-content-root">
                    <children>

                        <VBox fx:id="mainpanel" prefHeight="1000.0" prefWidth="1515.0">
                            <HBox.margin>
                                <Insets bottom="15.0" right="12.0" top="15.0"/>
                            </HBox.margin>
                        </VBox>

                        <VBox fx:id="instruction" prefHeight="1000.0" prefWidth="388.0" styleClass="sim-sidebar">
                            <HBox.margin>
                                <Insets bottom="15.0" left="7.0" right="8.0" top="15.0"/>
                            </HBox.margin>
                        </VBox>

                    </children>
                    <padding>
                        <Insets top="10.0"/>
                    </padding>
                </HBox>
            </content>
        </ScrollPane>

    </children>
</VBox>
