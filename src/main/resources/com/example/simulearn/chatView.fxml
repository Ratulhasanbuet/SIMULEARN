<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox fillHeight="true" prefHeight="800" prefWidth="1300" stylesheets="@realmolecule.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.simulearn.chatController">

   <!-- LEFT: User List -->
   <VBox prefWidth="200" style="-fx-background-color:#ecf0f1;">
      <Label alignment="BASELINE_CENTER" maxWidth="Infinity" prefHeight="68.0" prefWidth="200.0" style="-fx-background-color: #2c3e50;" text="Users" textFill="WHITE">
         <font>
            <Font name="System Bold" size="18.0" />
         </font></Label>
      <ListView fx:id="userList" prefHeight="690.0" prefWidth="200.0" VBox.vgrow="ALWAYS" />
   </VBox>

   <!-- RIGHT: Chat Area -->
   <VBox fillWidth="true" HBox.hgrow="ALWAYS">

      <!-- Top Bar -->
      <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color:#2c3e50;">
         <padding>
            <Insets bottom="10" left="15" right="15" top="10" />
         </padding>

         <Label style="-fx-text-fill:white; -fx-font-size:18px; -fx-font-weight:bold;" text="Chat Room" />
         <Pane HBox.hgrow="ALWAYS" />
         <Button fx:id="backButton" onAction="#onBackClicked" styleClass="button-74" text="Back" />
      </HBox>

      <!-- Chat Messages ScrollPane -->
      <ScrollPane fx:id="chatScrollPane" fitToWidth="true" style="-fx-background:#f4f6f7;" VBox.vgrow="ALWAYS">
         <VBox fx:id="chatBox" spacing="10">
            <padding>
               <Insets bottom="10" left="10" right="10" top="10" />
            </padding>
         </VBox>
      </ScrollPane>

      <!-- Message Input -->
      <HBox spacing="10" style="-fx-background-color:#ecf0f1;">
         <padding>
            <Insets bottom="10" left="10" right="10" top="10" />
         </padding>
         <Button fx:id="attachButton" onAction="#onAttachClicked" styleClass="button-27" text="Attach" />

         <TextArea fx:id="messageField" prefHeight="80" wrapText="true" HBox.hgrow="ALWAYS" />
         <Button fx:id="sendButton" layoutX="1009.0" layoutY="20.0" onAction="#onSendClicked" styleClass="button-27" text="Send" />
      </HBox>

   </VBox>

</HBox>
