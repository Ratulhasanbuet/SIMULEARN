<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="1080.0" prefWidth="1920.0" stylesheets="@menu.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.simulearn.biologyMenuController">

    <children>

        <ScrollPane fitToWidth="true" styleClass="main-scroll">
            <content>

                <VBox spacing="0" styleClass="page-root">

                    <!-- ══════ NAVBAR ══════ -->
                    <HBox alignment="CENTER_LEFT" spacing="0" styleClass="navbar">

                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label styleClass="brand-icon" text="🌿" />
                            <Label styleClass="brand-name" text="SimuLearn" />
                        </HBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <HBox alignment="CENTER" spacing="6">
                            <Button mnemonicParsing="false" onAction="#onHomeButtonClicked" styleClass="nav-btn" text="Home" />
                            <Button mnemonicParsing="false" styleClass="nav-btn" text="About" />
                            <Button mnemonicParsing="false" styleClass="nav-btn" text="Login" />
                            <Button mnemonicParsing="false" styleClass="nav-btn-exit" text="Exit" />
                        </HBox>

                        <HBox.margin>
                            <Insets right="50.0" />
                        </HBox.margin>
                    </HBox>

                    <!-- ══════ PAGE HEADER ══════ -->
                    <VBox alignment="CENTER" spacing="12" styleClass="page-header">

                        <Label styleClass="hero-badge" text="🌱   Biology Simulations" />

                        <Label styleClass="hero-title" text="Biology" />
                        <Label styleClass="hero-title-accent" text="Lab Simulations" />

                        <Label maxWidth="800" styleClass="hero-subtitle" text="Explore the living world through hands-on virtual experiments. From micropipetting to DNA ligation — learn by doing." wrapText="true" />

                    </VBox>

                    <!-- ══════ SIMULATION CARDS ══════ -->
                    <VBox alignment="CENTER" spacing="14" styleClass="cards-section">

                        <Label styleClass="section-title" text="Choose a Simulation" />
                        <Label styleClass="section-sub" text="Click any card to launch the simulation" />

                        <HBox alignment="CENTER" spacing="40" styleClass="cards-row">

                            <!-- Micropipetting -->
                            <Button mnemonicParsing="false" onAction="#onMicropipettingSolutionButtonClicked" styleClass="sim-card">
                                <graphic>
                                    <VBox alignment="CENTER" spacing="16" styleClass="sim-card-inner">
                                        <ImageView fitHeight="201.0" fitWidth="414.0" pickOnBounds="true" preserveRatio="true">
                                            <image>
                                                <Image url="@../../../Images/Micropipetting%20Solutions%20-%20visual%20selection.png" />
                                            </image>
                                        </ImageView>
                                        <VBox alignment="CENTER" spacing="6">
                                            <Label styleClass="sim-card-title" text="Micropipetting Solutions" />
                                            <Label maxWidth="300" styleClass="sim-card-desc" text="Master the art of precise liquid handling used in every real biology lab." wrapText="true" />
                                            <Label styleClass="sim-card-tag-bio" text="🧬  Lab Technique" />
                                        </VBox>
                                    </VBox>
                                </graphic>
                            </Button>

                            <!-- DNA Ligation -->
                            <Button mnemonicParsing="false" onAction="#ligationbuttonclicked" styleClass="sim-card">
                                <graphic>
                                    <VBox alignment="CENTER" spacing="16" styleClass="sim-card-inner">
                                        <ImageView fitHeight="200.0" fitWidth="320.0" pickOnBounds="true" preserveRatio="true">
                                            <image>
                                                <Image url="@../../../Images/DNA%20Ligation%20Simulation_%20Uniting%20Fragments%20for%20Gene%20Expression%20-%20visual%20selection.png" />
                                            </image>
                                        </ImageView>
                                        <VBox alignment="CENTER" spacing="6">
                                            <Label styleClass="sim-card-title" text="DNA Ligation" />
                                            <Label maxWidth="300" styleClass="sim-card-desc" text="Join DNA fragments together and explore gene expression in a virtual lab." wrapText="true" />
                                            <Label styleClass="sim-card-tag-dna" text="🧪  Genetics" />
                                        </VBox>
                                    </VBox>
                                </graphic>
                            </Button>

                            <!-- Protein Purification -->
                            <Button mnemonicParsing="false" onAction="#onPPCCButtonClicked" styleClass="sim-card">
                                <graphic>
                                    <VBox alignment="CENTER" spacing="16" styleClass="sim-card-inner">
                                        <ImageView fitHeight="260.0" fitWidth="412.0" pickOnBounds="true" preserveRatio="true">
                                            <image>
                                                <Image url="@../../../Images/Protein%20Purification%20from%20E.%20coli_%20A%20Simulation%20Guide%20-%20visual%20selection.png" />
                                            </image>
                                        </ImageView>
                                        <VBox alignment="CENTER" spacing="6">
                                            <Label styleClass="sim-card-title" text="Protein Purification" />
                                            <Label maxWidth="300" styleClass="sim-card-desc" text="Purify proteins from E. coli step by step in this guided simulation." wrapText="true" />
                                            <Label styleClass="sim-card-tag-protein" text="⚗️  Biochemistry" />
                                        </VBox>
                                    </VBox>
                                </graphic>
                            </Button>

                        </HBox>
                    </VBox>

                    <!-- ══════ FOOTER ══════ -->
                    <HBox alignment="CENTER" styleClass="footer">
                        <Label styleClass="footer-text" text="© 2025 SimuLearn  •  Made with ❤️ for curious minds" />
                    </HBox>

                </VBox>
            </content>
        </ScrollPane>

    </children>
</StackPane>
