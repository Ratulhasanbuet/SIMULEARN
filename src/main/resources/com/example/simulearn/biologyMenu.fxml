<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>


<StackPane
        prefHeight="1080.0"
        prefWidth="1920.0"
        stylesheets="@menu.css"
        xmlns="http://javafx.com/javafx/25"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.example.simulearn.SimuLearn.Biology.biologyMenuController">

    <children>

        <ScrollPane styleClass="main-scroll" fitToWidth="true">
            <content>

                <VBox styleClass="page-root" spacing="0">

                    <HBox alignment="CENTER_LEFT" spacing="0" styleClass="navbar">

                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <FontIcon iconLiteral="mdi2d-dna" styleClass="brand-icon"/>
                            <Label styleClass="brand-name" text="SimuLearn"/>
                        </HBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <HBox fx:id="loggedOutBox" alignment="CENTER" spacing="6">
                            <Button mnemonicParsing="false" onAction="#onHomeButtonClicked" styleClass="nav-btn" text="Home"/>
                            <Button mnemonicParsing="false" onAction="#about" styleClass="nav-btn" text="About"/>
                            <Button mnemonicParsing="false" onAction="#login" styleClass="nav-btn" text="Login"/>
                            <Button mnemonicParsing="false" onAction="#exit" styleClass="nav-btn-exit" text="Exit"/>
                        </HBox>


                        <HBox fx:id="loggedInBox" alignment="CENTER" managed="false" spacing="10" visible="false">
                            <Button mnemonicParsing="false" onAction="#onHomeButtonClicked" styleClass="nav-btn" text="Home"/>
                            <Button mnemonicParsing="false" onAction="#about" styleClass="nav-btn" text="About"/>


                            <HBox alignment="CENTER" spacing="10" styleClass="user-chip">
                                <Label fx:id="userAvatarLabel" styleClass="user-avatar" text="U"/>
                                <VBox alignment="CENTER_LEFT" spacing="1">
                                    <Label styleClass="user-chip-greeting" text="Signed in as"/>
                                    <Label fx:id="usernameLabel" styleClass="user-chip-name" text="username"/>
                                </VBox>
                            </HBox>

                            <Button mnemonicParsing="false" onAction="#logout" styleClass="nav-btn-logout"
                                    text="Logout"/>
                            <Button mnemonicParsing="false" onAction="#exit" styleClass="nav-btn-exit" text="Exit"/>
                        </HBox>

                        <HBox.margin>
                            <Insets right="50.0"/>
                        </HBox.margin>
                    </HBox>

                    <VBox styleClass="page-header" alignment="CENTER" spacing="12">

                        <Label styleClass="hero-badge" text="🌱   Biology Simulations"/>

                        <Label styleClass="hero-title" text="Biology"/>
                        <Label styleClass="hero-title-accent" text="Lab Simulations"/>

                        <Label styleClass="hero-subtitle" wrapText="true" maxWidth="800"
                               text="Explore the living world through hands-on virtual experiments. From micropipetting to DNA ligation — learn by doing."/>

                    </VBox>

                    <VBox alignment="CENTER" spacing="14" styleClass="cards-section">

                        <Label styleClass="section-title" text="Choose a Simulation"/>
                        <Label styleClass="section-sub" text="Click any card to launch the simulation"/>

                        <HBox alignment="CENTER" spacing="40" styleClass="cards-row">

                            <Button mnemonicParsing="false"
                                    onAction="#onMicropipettingSolutionButtonClicked"
                                    styleClass="sim-card">
                                <graphic>
                                    <VBox alignment="CENTER" spacing="16" styleClass="sim-card-inner">
                                        <ImageView fitHeight="200.0" fitWidth="320.0"
                                                   pickOnBounds="true" preserveRatio="true">
                                            <image>
                                                <Image url="@../../../Images/Micropipetting%20Solutions%20-%20visual%20selection.png"/>
                                            </image>
                                        </ImageView>
                                        <VBox alignment="CENTER" spacing="6">
                                            <Label styleClass="sim-card-title" text="Micropipetting Solutions"/>
                                            <Label styleClass="sim-card-desc" wrapText="true" maxWidth="300"
                                                   text="Master the art of precise liquid handling used in every real biology lab."/>
                                            <Label styleClass="sim-card-tag-bio" text="🧬  Lab Technique"/>
                                        </VBox>
                                    </VBox>
                                </graphic>
                            </Button>

                            <Button mnemonicParsing="false"
                                    onAction="#ligationbuttonclicked"
                                    styleClass="sim-card">
                                <graphic>
                                    <VBox alignment="CENTER" spacing="16" styleClass="sim-card-inner">
                                        <ImageView fitHeight="200.0" fitWidth="320.0"
                                                   pickOnBounds="true" preserveRatio="true">
                                            <image>
                                                <Image url="@../../../Images/DNA%20Ligation%20Simulation_%20Uniting%20Fragments%20for%20Gene%20Expression%20-%20visual%20selection.png"/>
                                            </image>
                                        </ImageView>
                                        <VBox alignment="CENTER" spacing="6">
                                            <Label styleClass="sim-card-title" text="DNA Ligation"/>
                                            <Label styleClass="sim-card-desc" wrapText="true" maxWidth="300"
                                                   text="Join DNA fragments together and explore gene expression in a virtual lab."/>
                                            <Label styleClass="sim-card-tag-dna" text="🧪  Genetics"/>
                                        </VBox>
                                    </VBox>
                                </graphic>
                            </Button>

                            <Button mnemonicParsing="false"
                                    onAction="#onPPCCButtonClicked"
                                    styleClass="sim-card">
                                <graphic>
                                    <VBox alignment="CENTER" spacing="16" styleClass="sim-card-inner">
                                        <ImageView fitHeight="200.0" fitWidth="320.0"
                                                   pickOnBounds="true" preserveRatio="true">
                                            <image>
                                                <Image url="@../../../Images/Protein%20Purification%20from%20E.%20coli_%20A%20Simulation%20Guide%20-%20visual%20selection.png"/>
                                            </image>
                                        </ImageView>
                                        <VBox alignment="CENTER" spacing="6">
                                            <Label styleClass="sim-card-title" text="Protein Purification"/>
                                            <Label styleClass="sim-card-desc" wrapText="true" maxWidth="300"
                                                   text="Purify proteins from E. coli step by step in this guided simulation."/>
                                            <Label styleClass="sim-card-tag-protein" text="⚗️  Biochemistry"/>
                                        </VBox>
                                    </VBox>
                                </graphic>
                            </Button>

                        </HBox>
                    </VBox>

                    <HBox styleClass="footer" alignment="CENTER">
                        <Label styleClass="footer-text" text="© 2025 SimuLearn  •  Made with ❤️ for curious minds"/>
                    </HBox>

                </VBox>
            </content>
        </ScrollPane>

    </children>
</StackPane>
