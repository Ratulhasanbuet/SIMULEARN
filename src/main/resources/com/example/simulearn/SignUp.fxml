<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane
    prefHeight="1080.0"
    prefWidth="1920.0"
    stylesheets="@menu.css"
    xmlns="http://javafx.com/javafx/25"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.example.simulearn.SignUpController">

    <children>

        <HBox spacing="0" prefHeight="1080" prefWidth="1920">

            <!-- ══ LEFT PANEL ══ -->
            <VBox styleClass="auth-left-panel" alignment="CENTER" spacing="30"
                  prefWidth="860" prefHeight="1080">

                <Label styleClass="auth-brand-icon" text="🌿"/>
                <Label styleClass="auth-brand-name" text="SimuLearn"/>
                <Label styleClass="auth-brand-tagline" maxWidth="500" wrapText="true"
                       text="Join thousands of students learning science through interactive simulations."/>

                <VBox spacing="14" alignment="CENTER">
                    <HBox spacing="14" alignment="CENTER">
                        <Label styleClass="auth-pill-physics" text="⚡  Physics"/>
                        <Label styleClass="auth-pill-chem"    text="🧪  Chemistry"/>
                    </HBox>
                    <HBox spacing="14" alignment="CENTER">
                        <Label styleClass="auth-pill-math"    text="📐  Mathematics"/>
                        <Label styleClass="auth-pill-bio"     text="🌿  Biology"/>
                    </HBox>
                </VBox>

                <Label styleClass="auth-left-footer" text="Free · Offline · Interactive"/>

            </VBox>

            <!-- ══ RIGHT PANEL — Sign Up Form ══ -->
            <VBox alignment="CENTER" HBox.hgrow="ALWAYS" styleClass="auth-right-panel">

                <VBox styleClass="auth-card" alignment="CENTER" spacing="0">

                    <Label styleClass="auth-card-title" text="Create Account"/>
                    <Label styleClass="auth-card-subtitle" text="Sign up and start exploring simulations"/>

                    <VBox spacing="18" styleClass="auth-form">

                        <!-- Username -->
                        <VBox spacing="6">
                            <Label styleClass="auth-field-label" text="Username"/>
                            <TextField fx:id="usernameField"
                                       styleClass="auth-input"
                                       promptText="Choose a username"/>
                        </VBox>

                        <!-- Email -->
                        <VBox spacing="6">
                            <Label styleClass="auth-field-label" text="Email"/>
                            <TextField fx:id="emailField"
                                       styleClass="auth-input"
                                       promptText="Enter your email address"/>
                        </VBox>

                        <!-- Password -->
                        <VBox spacing="6">
                            <Label styleClass="auth-field-label" text="Password"/>
                            <PasswordField fx:id="passwordField"
                                           styleClass="auth-input"
                                           promptText="Create a password"/>
                        </VBox>

                        <!-- Confirm Password -->
                        <VBox spacing="6">
                            <Label styleClass="auth-field-label" text="Confirm Password"/>
                            <PasswordField fx:id="confirmPasswordField"
                                           styleClass="auth-input"
                                           promptText="Re-enter your password"/>
                        </VBox>

                        <!-- Remember Me -->
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <CheckBox fx:id="rememberMe" styleClass="auth-checkbox"
                                      text="Keep me signed in"/>
                        </HBox>

                        <!-- Error / Success label -->
                        <Label fx:id="messageLabel" styleClass="auth-error"
                               text="" wrapText="true" maxWidth="360"/>

                        <!-- Sign Up Button -->
                        <Button mnemonicParsing="false" onAction="#handleSignUp"
                                styleClass="btn-glow-green auth-submit-btn"
                                text="Create Account →"/>

                        <HBox alignment="CENTER" spacing="6">
                            <Label styleClass="auth-switch-text" text="Already have an account?"/>
                            <Hyperlink onAction="#goToLogin" styleClass="auth-link" text="Sign in"/>
                        </HBox>

                        <HBox alignment="CENTER">
                            <Hyperlink onAction="#goHome" styleClass="auth-link-muted" text="← Back to Home"/>
                        </HBox>

                    </VBox>
                </VBox>
            </VBox>

        </HBox>

    </children>
</StackPane>
