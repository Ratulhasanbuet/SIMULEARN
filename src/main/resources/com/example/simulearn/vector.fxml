                     <RadioButton fx:id="optionB" prefHeight="36.0" prefWidth="84.0" text="B. 360/n" />
                     <RadioButton fx:id="optionC" prefHeight="30.0" prefWidth="84.0" text="C. 180/n" />
                     <RadioButton fx:id="optionD" prefHeight="36.0" prefWidth="131.0" text="D. Not possible" />
                  </VBox>

                  <Button onAction="#checkAnswer" prefHeight="30.0" prefWidth="113.0" style="-fx-background-color: #0078D7; -fx-text-fill: white;" text="Check Answer" />

