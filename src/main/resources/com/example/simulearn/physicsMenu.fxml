<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>


<?import javafx.geometry.Insets?>
<StackPane prefHeight="1080.0" prefWidth="1920.0" stylesheets="@menu.css" xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.simulearn.SimuLearn.Physics.physicsMenuController">

    <children>

        <ScrollPane fitToWidth="true" styleClass="main-scroll">
            <content>

                <VBox spacing="0" styleClass="page-root">
                    <HBox alignment="CENTER_LEFT" spacing="0" styleClass="navbar">

                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <FontIcon iconLiteral="mdi2d-dna" styleClass="brand-icon"/>
                            <Label styleClass="brand-name" text="SimuLearn"/>
                        </HBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <HBox fx:id="loggedOutBox" alignment="CENTER" spacing="6">
                            <Button mnemonicParsing="false" onAction="#onHomeButtonClicked" styleClass="nav-btn"
                                    text="Home"/>
                            <Button mnemonicParsing="false" onAction="#about" styleClass="nav-btn" text="About"/>
                            <Button mnemonicParsing="false" onAction="#login" styleClass="nav-btn" text="Login"/>
                            <Button mnemonicParsing="false" onAction="#exit" styleClass="nav-btn-exit" text="Exit"/>
                        </HBox>

                        <HBox fx:id="loggedInBox" alignment="CENTER" managed="false" spacing="10" visible="false">
                            <Button mnemonicParsing="false" onAction="#onHomeButtonClicked" styleClass="nav-btn"
                                    text="Home"/>
                            <Button mnemonicParsing="false" onAction="#about" styleClass="nav-btn" text="About"/>

                            <HBox alignment="CENTER" spacing="10" styleClass="user-chip">
                                <Label fx:id="userAvatarLabel" styleClass="user-avatar" text="U"/>
                                <VBox alignment="CENTER_LEFT" spacing="1">
                                    <Label styleClass="user-chip-greeting" text="Signed in as"/>
                                    <Label fx:id="usernameLabel" styleClass="user-chip-name" text="username"/>
                                </VBox>
                            </HBox>

                            <Button mnemonicParsing="false" onAction="#logout" styleClass="nav-btn-logout"
                                    text="Logout"/>
                            <Button mnemonicParsing="false" onAction="#exit" styleClass="nav-btn-exit" text="Exit"/>
                        </HBox>

                        <HBox.margin>
                            <Insets right="50.0"/>
                        </HBox.margin>
                    </HBox>

                    <VBox alignment="CENTER" spacing="12" styleClass="page-header">

                        <Label styleClass="hero-badge" text="⚡   Physics Simulations"/>

                        <Label styleClass="hero-title" text="Physics"/>
                        <Label styleClass="hero-title-accent" text="Lab Simulations"/>

                        <Label maxWidth="800" styleClass="hero-subtitle"
                               text="Experience the laws of physics through interactive virtual experiments. From floating objects to flying projectiles — see it, feel it, understand it."
                               wrapText="true"/>

                    </VBox>

                    <VBox alignment="CENTER" spacing="14" styleClass="cards-section">

                        <Label styleClass="section-title" text="Choose a Simulation"/>
                        <Label styleClass="section-sub" text="Click any card to launch the simulation"/>

                        <HBox alignment="CENTER" spacing="40" styleClass="cards-row">

                            <!-- Buoyancy -->
                            <Button mnemonicParsing="false" onAction="#onBuoyancyClick" styleClass="sim-card">
                                <graphic>
                                    <VBox alignment="CENTER" spacing="16" styleClass="sim-card-inner">
                                        <ImageView fitHeight="200.0" fitWidth="320.0" pickOnBounds="true"
                                                   preserveRatio="true">
                                            <image>
                                                <Image url="@../../../Images/Buoyancy%20-%20visual%20selection.png"/>
                                            </image>
                                        </ImageView>
                                        <VBox alignment="CENTER" spacing="6">
                                            <Label styleClass="sim-card-title" text="Buoyancy"/>
                                            <Label maxWidth="300" styleClass="sim-card-desc"
                                                   text="Explore Archimedes' principle and discover why objects float or sink in fluids."
                                                   wrapText="true"/>
                                            <Label styleClass="sim-card-tag-bio" text="🌊  Fluid Mechanics"/>
                                        </VBox>
                                    </VBox>
                                </graphic>
                            </Button>

                            <Button mnemonicParsing="false" onAction="#onProjectileButtonClicked" styleClass="sim-card">
                                <graphic>
                                    <VBox alignment="CENTER" spacing="16" styleClass="sim-card-inner">
                                        <ImageView fitHeight="200.0" fitWidth="320.0" pickOnBounds="true"
                                                   preserveRatio="true">
                                            <image>
                                                <Image url="@../../../Images/Understanding%20Projectile%20Motion%20-%20visual%20selection.png"/>
                                            </image>
                                        </ImageView>
                                        <VBox alignment="CENTER" spacing="6">
                                            <Label styleClass="sim-card-title" text="Projectile Motion"/>
                                            <Label maxWidth="300" styleClass="sim-card-desc"
                                                   text="Launch objects and analyze trajectories using real physics equations."
                                                   wrapText="true"/>
                                            <Label styleClass="sim-card-tag-dna" text="🏀  Kinematics"/>
                                        </VBox>
                                    </VBox>
                                </graphic>
                            </Button>

                            <Button mnemonicParsing="false" onAction="#onLogicCircuitClicked" styleClass="sim-card">
                                <graphic>
                                    <VBox alignment="CENTER" spacing="16" styleClass="sim-card-inner">
                                        <ImageView fitHeight="200.0" fitWidth="320.0" pickOnBounds="true"
                                                   preserveRatio="true">
                                            <!-- No dedicated image found, using placeholder label -->
                                        </ImageView>
                                        <VBox alignment="CENTER" spacing="6">
                                            <Label styleClass="sim-card-icon-large" text="🔌"/>
                                            <Label styleClass="sim-card-title" text="Logic Circuit"/>
                                            <Label maxWidth="300" styleClass="sim-card-desc"
                                                   text="Build and simulate digital logic gates — AND, OR, NOT and beyond."
                                                   wrapText="true"/>
                                            <Label styleClass="sim-card-tag-protein" text="💡  Electronics"/>
                                        </VBox>
                                    </VBox>
                                </graphic>
                            </Button>

                        </HBox>
                    </VBox>

                    <HBox alignment="CENTER" styleClass="footer">
                        <Label styleClass="footer-text" text="© 2025 SimuLearn  •  Made with ❤️ for curious minds"/>
                    </HBox>

                </VBox>
            </content>
        </ScrollPane>

    </children>
</StackPane>
