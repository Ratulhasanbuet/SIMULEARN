<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="1080.0" prefWidth="1920.0" stylesheets="@menu.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.simulearn.chemistryMenuController">

    <children>

        <ScrollPane fitToWidth="true" styleClass="main-scroll">
            <content>

                <VBox spacing="0" styleClass="page-root">
               <HBox alignment="CENTER_LEFT" spacing="0" styleClass="navbar">
                  <children>
                     <HBox alignment="CENTER_LEFT" spacing="12">
                        <children>
                           <Label styleClass="brand-icon" text="🌿" />
                           <Label styleClass="brand-name" text="SimuLearn" />
                        </children>
                     </HBox>
                     <Region HBox.hgrow="ALWAYS" />
                     <HBox fx:id="loggedOutBox" alignment="CENTER" spacing="6">
                        <children>
                           <Button mnemonicParsing="false" onAction="#onHomeButtonClicked" styleClass="nav-btn" text="Home" />
                           <Button mnemonicParsing="false" onAction="#about" styleClass="nav-btn" text="About" />
                           <Button mnemonicParsing="false" onAction="#login" styleClass="nav-btn" text="Login" />
                           <Button mnemonicParsing="false" styleClass="nav-btn-exit" onAction="#exit" text="Exit" />
                        </children>
                     </HBox>
                     <HBox fx:id="loggedInBox" alignment="CENTER" managed="false" spacing="10" visible="false">
                        <children>
                           <Button mnemonicParsing="false" onAction="#onHomeButtonClicked" styleClass="nav-btn" text="Home" />
                           <Button mnemonicParsing="false" onAction="#about" styleClass="nav-btn" text="About" />
                           <HBox alignment="CENTER" spacing="10" styleClass="user-chip">
                              <children>
                                 <Label fx:id="userAvatarLabel" styleClass="user-avatar" text="U" />
                                 <VBox alignment="CENTER_LEFT" spacing="1">
                                    <children>
                                       <Label styleClass="user-chip-greeting" text="Signed in as" />
                                       <Label fx:id="usernameLabel" styleClass="user-chip-name" text="username" />
                                    </children>
                                 </VBox>
                              </children>
                           </HBox>
                           <Button mnemonicParsing="false" onAction="#logout" styleClass="nav-btn-logout" text="Logout" />
                        </children>
                     </HBox>
                  </children>
               </HBox>

                    <!-- ══════ PAGE HEADER ══════ -->
                    <VBox alignment="CENTER" spacing="12" styleClass="page-header">

                        <Label styleClass="hero-badge" text="🧪   Chemistry Simulations" />

                        <Label styleClass="hero-title" text="Chemistry" />
                        <Label styleClass="hero-title-accent" text="Lab Simulations" />

                        <Label maxWidth="800" styleClass="hero-subtitle" text="Visualize molecules, observe reactions, and run experiments in a safe virtual chemistry lab. No goggles required." wrapText="true" />

                    </VBox>

                    <!-- ══════ SIMULATION CARDS ══════ -->
                    <VBox alignment="CENTER" spacing="14" styleClass="cards-section">

                        <Label styleClass="section-title" text="Choose a Simulation" />
                        <Label styleClass="section-sub" text="Click any card to launch the simulation" />

                        <HBox alignment="CENTER" spacing="40" styleClass="cards-row">

                            <!-- Real Molecule -->
                            <Button mnemonicParsing="false" onAction="#onRealMoleculeButtonClicked" styleClass="sim-card">
                                <graphic>
                                    <VBox alignment="CENTER" spacing="16" styleClass="sim-card-inner">
                                        <ImageView fitHeight="366.0" fitWidth="329.0" pickOnBounds="true" preserveRatio="true">
                                            <image>
                                                <Image url="@../../../Images/Understanding%20VSEPR%20Theory%20-%20visual%20selection.png" />
                                            </image>
                                        </ImageView>
                                        <VBox alignment="CENTER" spacing="6">
                                            <Label styleClass="sim-card-title" text="Real Molecule Viewer" />
                                            <Label maxWidth="300" styleClass="sim-card-desc" text="Explore 3D molecular geometry — tetrahedral, linear, bent and more." wrapText="true" />
                                            <Label styleClass="sim-card-tag-bio" text="🔬  Molecular Geometry" />
                                        </VBox>
                                    </VBox>
                                </graphic>
                            </Button>

                            <!-- Multi Molecule -->
                            <Button mnemonicParsing="false" onAction="#onMultiMoleculeButtonClicked" styleClass="sim-card">
                                <graphic>
                                    <VBox alignment="CENTER" spacing="16" styleClass="sim-card-inner">
                                        <ImageView fitHeight="389.0" fitWidth="319.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@../../../Images/Aromatic%20Organic%20and%20Inorganic%20Molecular%20View%20-%20visual%20selection.png" />
                                 </image>
                                        </ImageView>
                                        <VBox alignment="CENTER" spacing="6">
                                            <Label styleClass="sim-card-title" text="Multi Molecule View" />
                                            <Label maxWidth="300" styleClass="sim-card-desc" text="Compare and visualize multiple molecular structures side by side." wrapText="true" />
                                            <Label styleClass="sim-card-tag-dna" text="⚗️  Organic Chemistry" />
                                        </VBox>
                                    </VBox>
                                </graphic>
                            </Button>

                            <!-- Flame Test -->
                            <Button mnemonicParsing="false" onAction="#onFlameTestClicked" styleClass="sim-card">
                                <graphic>
                                    <VBox alignment="CENTER" spacing="16" styleClass="sim-card-inner">
                              <ImageView fitHeight="269.0" fitWidth="339.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@../../../Images/Flame%20Test%20of%20Compounds%20and%20Color%20Transitions%20-%20visual%20selection.png" />
                                 </image>
                              </ImageView>
                                        <VBox alignment="CENTER" spacing="6">
                                            <Label styleClass="sim-card-title" text="Flame Test" />
                                            <Label maxWidth="300" styleClass="sim-card-desc" text="Identify metal ions by the colour they produce in a flame — virtually and safely." wrapText="true" />
                                            <Label styleClass="sim-card-tag-protein" text="💡  Analytical Chemistry" />
                                        </VBox>
                                    </VBox>
                                </graphic>
                            </Button>

                        </HBox>
                    </VBox>

                    <!-- ══════ FOOTER ══════ -->
                    <HBox alignment="CENTER" styleClass="footer">
                        <Label styleClass="footer-text" text="© 2025 SimuLearn  •  Made with ❤️ for curious minds" />
                    </HBox>

                </VBox>
            </content>
        </ScrollPane>

    </children>
</StackPane>
