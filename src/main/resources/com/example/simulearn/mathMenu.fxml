<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>


<?import javafx.geometry.Insets?>
<StackPane prefHeight="1080.0" prefWidth="1920.0" stylesheets="@menu.css" xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.simulearn.SimuLearn.Math.mathMenuController">

    <children>

        <ScrollPane fitToWidth="true" styleClass="main-scroll">
            <content>

                <VBox spacing="0" styleClass="page-root">
                    <!-- ══════ NAVBAR ══════ -->
                    <HBox alignment="CENTER_LEFT" spacing="0" styleClass="navbar">

                        <!-- Brand -->
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <FontIcon iconLiteral="mdi2d-dna" styleClass="brand-icon"/>
                            <Label styleClass="brand-name" text="SimuLearn"/>
                        </HBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <!-- ── Logged-OUT state (visible by default) ── -->
                        <HBox fx:id="loggedOutBox" alignment="CENTER" spacing="6">
                            <Button mnemonicParsing="false" onAction="#onHomeButtonClicked" styleClass="nav-btn" text="Home"/>
                            <Button mnemonicParsing="false" onAction="#about" styleClass="nav-btn" text="About"/>
                            <Button mnemonicParsing="false" onAction="#login" styleClass="nav-btn" text="Login"/>
                            <Button mnemonicParsing="false" onAction="#exit" styleClass="nav-btn-exit" text="Exit"/>
                        </HBox>

                        <!-- ── Logged-IN state (hidden until login) ── -->
                        <HBox fx:id="loggedInBox" alignment="CENTER" managed="false" spacing="10" visible="false">
                            <Button mnemonicParsing="false" onAction="#onHomeButtonClicked" styleClass="nav-btn" text="Home"/>
                            <Button mnemonicParsing="false" onAction="#about" styleClass="nav-btn" text="About"/>

                            <!-- User avatar chip -->
                            <HBox alignment="CENTER" spacing="10" styleClass="user-chip">
                                <Label fx:id="userAvatarLabel" styleClass="user-avatar" text="U"/>
                                <VBox alignment="CENTER_LEFT" spacing="1">
                                    <Label styleClass="user-chip-greeting" text="Signed in as"/>
                                    <Label fx:id="usernameLabel" styleClass="user-chip-name" text="username"/>
                                </VBox>
                            </HBox>

                            <Button mnemonicParsing="false" onAction="#logout" styleClass="nav-btn-logout"
                                    text="Logout"/>
                            <Button mnemonicParsing="false" onAction="#exit" styleClass="nav-btn-exit" text="Exit"/>
                        </HBox>

                        <HBox.margin>
                            <Insets right="50.0"/>
                        </HBox.margin>
                    </HBox>

                    <!-- ══════ PAGE HEADER ══════ -->
                    <VBox alignment="CENTER" spacing="12" styleClass="page-header">

                        <Label styleClass="hero-badge" text="📐   Mathematics Simulations"/>

                        <Label styleClass="hero-title" text="Mathematics"/>
                        <Label styleClass="hero-title-accent" text="Lab Simulations"/>

                        <Label maxWidth="800" styleClass="hero-subtitle"
                               text="See mathematics in motion. Interact with vectors, graphs, and geometric shapes to build real intuition for abstract concepts."
                               wrapText="true"/>

                    </VBox>

                    <!-- ══════ SIMULATION CARDS ══════ -->
                    <VBox alignment="CENTER" spacing="14" styleClass="cards-section">

                        <Label styleClass="section-title" text="Choose a Simulation"/>
                        <Label styleClass="section-sub" text="Click any card to launch the simulation"/>

                        <HBox alignment="CENTER" spacing="40" styleClass="cards-row">

                            <!-- Card 1 — Vector (already exists) -->
                            <Button mnemonicParsing="false" onAction="#vectorClicked" styleClass="sim-card">
                                <graphic>
                                    <VBox alignment="CENTER" spacing="16" styleClass="sim-card-inner">
                                        <!-- TODO: replace emoji with ImageView when image is ready -->
                                        <Label styleClass="sim-card-icon-large" text="➡️"/>
                                        <VBox alignment="CENTER" spacing="6">
                                            <Label styleClass="sim-card-title" text="Vector"/>
                                            <Label maxWidth="300" styleClass="sim-card-desc"
                                                   text="Visualize vector addition, subtraction and direction in 2D space."
                                                   wrapText="true"/>
                                            <Label styleClass="sim-card-tag-bio" text="📐  Linear Algebra"/>
                                        </VBox>
                                    </VBox>
                                </graphic>
                            </Button>

                            <!-- Card 2 — Placeholder (add onAction + image later) -->
                            <Button onAction="#eulerClicked" mnemonicParsing="false" styleClass="sim-card">
                                <graphic>
                                    <VBox alignment="CENTER" spacing="16" styleClass="sim-card-inner">
                                        <!-- TODO: replace emoji with ImageView when image is ready -->
                                        <Label styleClass="sim-card-icon-large" text="📈"/>
                                        <VBox alignment="CENTER" spacing="6">
                                            <!-- TODO: update title and description -->
                                            <Label styleClass="sim-card-title" text="Simulation 2"/>
                                            <Label maxWidth="300" styleClass="sim-card-desc"
                                                   text="Description coming soon. Add your simulation title and details here."
                                                   wrapText="true"/>
                                            <Label styleClass="sim-card-tag-dna" text="📊  Coming Soon"/>
                                        </VBox>
                                    </VBox>
                                </graphic>
                            </Button>

                            <!-- Card 3 — Placeholder (add onAction + image later) -->
                            <Button mnemonicParsing="false" styleClass="sim-card">
                                <graphic>
                                    <VBox alignment="CENTER" spacing="16" styleClass="sim-card-inner">
                                        <!-- TODO: replace emoji with ImageView when image is ready -->
                                        <Label styleClass="sim-card-icon-large" text="📐"/>
                                        <VBox alignment="CENTER" spacing="6">
                                            <!-- TODO: update title and description -->
                                            <Label styleClass="sim-card-title" text="Simulation 3"/>
                                            <Label maxWidth="300" styleClass="sim-card-desc"
                                                   text="Description coming soon. Add your simulation title and details here."
                                                   wrapText="true"/>
                                            <Label styleClass="sim-card-tag-protein" text="🔢  Coming Soon"/>
                                        </VBox>
                                    </VBox>
                                </graphic>
                            </Button>

                        </HBox>
                    </VBox>

                    <!-- ══════ FOOTER ══════ -->
                    <HBox alignment="CENTER" styleClass="footer">
                        <Label styleClass="footer-text" text="© 2025 SimuLearn  •  Made with ❤️ for curious minds"/>
                    </HBox>

                </VBox>
            </content>
        </ScrollPane>

    </children>
</StackPane>
