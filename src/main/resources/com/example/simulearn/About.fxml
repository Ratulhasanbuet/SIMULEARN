<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="1080.0" prefWidth="1920.0" stylesheets="@menu.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.simulearn.AboutController">

    <children>

        <ScrollPane fitToWidth="true" styleClass="main-scroll">
            <content>

                <VBox spacing="0" styleClass="page-root">

                    <!-- ══════ NAVBAR ══════ -->
                    <HBox alignment="CENTER_LEFT" spacing="0" styleClass="navbar">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label styleClass="brand-icon" text="🌿" />
                            <Label styleClass="brand-name" text="SimuLearn" />
                        </HBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER" spacing="6">
                            <Button mnemonicParsing="false" onAction="#goHome" styleClass="nav-btn" text="Home" />
                            <Button mnemonicParsing="false" styleClass="nav-btn nav-btn-active" text="About" />
                            <Button mnemonicParsing="false" styleClass="nav-btn" text="Login" />
                            <Button mnemonicParsing="false" styleClass="nav-btn-exit" text="Exit" />
                        </HBox>
                        <HBox.margin>
                            <Insets right="50.0" />
                        </HBox.margin>
                    </HBox>

                    <!-- ══════ HERO HEADER ══════ -->
                    <VBox alignment="CENTER" spacing="16" styleClass="about-hero">
                        <Label styleClass="hero-badge" text="ℹ️   About SimuLearn" />
                        <Label styleClass="hero-title" text="What is" />
                        <Label styleClass="hero-title-accent" text="SimuLearn?" />
                        <Label maxWidth="900" styleClass="hero-subtitle" text="SimuLearn is a free, open-access interactive science learning platform that turns complex academic concepts into hands-on virtual experiments — making education more engaging, visual, and effective." wrapText="true" />
                    </VBox>

                    <!-- ══════ MISSION SECTION ══════ -->
                    <VBox alignment="CENTER" spacing="20" styleClass="about-section">

                        <Label styleClass="about-section-title" text="🎯  Our Mission" />
                        <Label maxWidth="1000" styleClass="about-body" text="We believe that true understanding comes from doing — not just reading. SimuLearn was built to bridge the gap between theoretical knowledge and real-world intuition. By simulating experiments that are too expensive, too dangerous, or simply impossible to run in a typical classroom, we empower students to learn at their own pace, in their own space." wrapText="true" />

                    </VBox>

                    <!-- ══════ SUBJECT CARDS ROW ══════ -->
                    <VBox alignment="CENTER" spacing="18" styleClass="about-section">

                        <Label styleClass="about-section-title" text="📚  What We Cover" />

                        <HBox alignment="CENTER" spacing="30">

                            <VBox alignment="CENTER" spacing="10" styleClass="about-subject-card">
                                <Label styleClass="about-subject-icon" text="⚡" />
                                <Label styleClass="about-subject-name" text="Physics" />
                                <Label maxWidth="220" styleClass="about-subject-detail" text="Buoyancy, Projectile Motion, Logic Circuits and more real-world physics phenomena." wrapText="true" />
                            </VBox>

                            <VBox alignment="CENTER" spacing="10" styleClass="about-subject-card">
                                <Label styleClass="about-subject-icon" text="🧪" />
                                <Label styleClass="about-subject-name" text="Chemistry" />
                                <Label maxWidth="220" styleClass="about-subject-detail" text="Molecular Geometry, Multi-Molecule Viewing, Flame Tests and chemical reactions." wrapText="true" />
                            </VBox>

                            <VBox alignment="CENTER" spacing="10" styleClass="about-subject-card">
                                <Label styleClass="about-subject-icon" text="📐" />
                                <Label styleClass="about-subject-name" text="Mathematics" />
                                <Label maxWidth="220" styleClass="about-subject-detail" text="Vectors, Graphs, and visual explorations of abstract mathematical concepts." wrapText="true" />
                            </VBox>

                            <VBox alignment="CENTER" spacing="10" styleClass="about-subject-card">
                                <Label styleClass="about-subject-icon" text="🌿" />
                                <Label styleClass="about-subject-name" text="Biology" />
                                <Label maxWidth="220" styleClass="about-subject-detail" text="Micropipetting, DNA Ligation, Protein Purification and essential lab techniques." wrapText="true" />
                            </VBox>

                        </HBox>
                    </VBox>

                    <!-- ══════ WHY SIMULEARN ══════ -->
                    <VBox alignment="CENTER" spacing="20" styleClass="about-section">

                        <Label styleClass="about-section-title" text="✨  Why SimuLearn?" />

                        <HBox alignment="CENTER" spacing="30">

                            <VBox alignment="TOP_LEFT" spacing="10" styleClass="about-feature-card">
                                <Label styleClass="about-feature-icon" text="🆓" />
                                <Label styleClass="about-feature-title" text="Completely Free" />
                                <Label styleClass="about-feature-desc" text="No subscriptions, no paywalls. Every simulation is free to use, forever." wrapText="true" />
                            </VBox>

                            <VBox alignment="TOP_LEFT" spacing="10" styleClass="about-feature-card">
                                <Label styleClass="about-feature-icon" text="🖥️" />
                                <Label styleClass="about-feature-desc-title" text="Works Offline" />
                                <Label styleClass="about-feature-desc" text="SimuLearn runs as a desktop app — no internet required after installation." wrapText="true" />
                            </VBox>

                            <VBox alignment="TOP_LEFT" spacing="10" styleClass="about-feature-card">
                                <Label styleClass="about-feature-icon" text="🔬" />
                                <Label styleClass="about-feature-title" text="Lab-Accurate" />
                                <Label styleClass="about-feature-desc" text="Simulations are designed to reflect real lab procedures and scientific principles." wrapText="true" />
                            </VBox>

                            <VBox alignment="TOP_LEFT" spacing="10" styleClass="about-feature-card">
                                <Label styleClass="about-feature-icon" text="🎓" />
                                <Label styleClass="about-feature-title" text="Student-First" />
                                <Label styleClass="about-feature-desc" text="Built by students, for students — with a focus on clarity and ease of use." wrapText="true" />
                            </VBox>

                        </HBox>
                    </VBox>

                    <!-- ══════ TEAM / BUILT BY ══════ -->
                    <VBox alignment="CENTER" spacing="14" styleClass="about-section">
                        <Label styleClass="about-section-title" text="👨‍💻  Built By" />
                        <Label maxWidth="900" styleClass="about-body" text="SimuLearn is our CSE-108 course  project developed with passion and curiosity. It was created using JavaFX — a modern Java UI framework — with the goal of making science education more accessible and interactive for everyone." wrapText="true" />

                        <HBox alignment="CENTER" spacing="16" styleClass="about-tech-row">
                            <Label styleClass="about-tech-badge" text="☕  Java" />
                            <Label styleClass="about-tech-badge" text="🎨  JavaFX" />
                            <Label styleClass="about-tech-badge" text="📦  FXML" />
                            <Label styleClass="about-tech-badge" text="🎓  IntelliJ IDEA" />
                        </HBox>
                    </VBox>

                    <!-- ══════ BACK BUTTON ══════ -->
                    <VBox alignment="CENTER" styleClass="about-back-section">
                        <Button mnemonicParsing="false" onAction="#goHome" styleClass="btn-glow-green" text="← Back to Home" />
                    </VBox>

                    <!-- ══════ FOOTER ══════ -->
                    <HBox alignment="CENTER" styleClass="footer">
                        <Label styleClass="footer-text" text="© 2026 SimuLearn  •  Made with ❤️ for curious minds" />
                    </HBox>

                </VBox>
            </content>
        </ScrollPane>

    </children>
</StackPane>
